/* pages/detail/detail.wxss - 景点详情页样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

/* ===== 加载骨架屏 ===== */
.loading-wrap {
  padding: var(--spacing-md);
}

.hero-skeleton {
  width: 100%;
  height: 500rpx;
  border-radius: 0;
  margin-bottom: var(--spacing-md);
}

.title-skeleton {
  width: 60%;
  height: 48rpx;
  border-radius: var(--radius-sm);
  margin-bottom: var(--spacing-md);
}

.text-skeleton {
  width: 100%;
  height: 28rpx;
  border-radius: var(--radius-sm);
  margin-bottom: var(--spacing-sm);
}

.text-skeleton.short {
  width: 70%;
}

/* ===== 错误状态 ===== */
.error-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
}

.error-text {
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
  margin-bottom: var(--spacing-md);
}

/* ===== 滚动容器 ===== */
.detail-scroll {
  flex: 1;
}

/* ===== 顶部大图 ===== */
.hero-image-wrap {
  position: relative;
  width: 100%;
  height: 560rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.hero-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: var(--spacing-md) var(--spacing-lg);
}

.hero-name {
  font-size: var(--font-size-xxl);
  font-weight: 700;
  color: #fff;
  display: block;
  margin-bottom: var(--spacing-xs);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.hero-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
}

.hero-character {
  font-size: var(--font-size-md);
  color: rgba(255, 255, 255, 0.9);
  font-weight: 500;
}

.hero-tags {
  display: flex;
  gap: 8rpx;
}

.hero-tags .tag {
  font-size: 18rpx;
}

/* ===== 内容区 ===== */
.detail-content {
  padding: var(--spacing-md);
}

.section {
  margin-bottom: var(--spacing-lg);
}

.section-header {
  margin-bottom: var(--spacing-sm);
}

.section-title {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: var(--color-text);
}

/* ===== 故事描述 ===== */
.story-text {
  font-size: var(--font-size-base);
  color: var(--color-text);
  line-height: 1.8;
  text-indent: 2em;
}

/* ===== 位置信息 ===== */
.location-info {
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.location-text {
  display: block;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  font-family: monospace;
  margin-bottom: 4rpx;
}

.location-area {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 500;
}

/* ===== 底部操作栏 ===== */
.bottom-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-divider);
  padding-bottom: calc(var(--spacing-sm) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
}

.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xs) var(--spacing-lg);
  border-radius: var(--radius-md);
  background: transparent;
  border: none;
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  transition: all 0.2s ease;
}

.bottom-btn::after {
  border: none;
}

.bottom-btn:active {
  background: var(--color-divider);
}

.bottom-btn.active {
  color: var(--color-primary);
}

.bottom-btn.primary {
  background: var(--color-primary);
  color: #fff;
  padding: var(--spacing-sm) var(--spacing-xl);
  border-radius: var(--radius-round);
}

.bottom-btn.primary:active {
  background: var(--color-primary-dark);
}

.bottom-btn-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 4rpx;
}

.bottom-btn.primary .bottom-btn-icon {
  filter: brightness(0) invert(1);
}

.bottom-btn-text {
  font-size: var(--font-size-xs);
}
