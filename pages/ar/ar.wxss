/* pages/ar/ar.wxss - AR实景识别页样式 */

/* ===== 全屏容器 ===== */
.ar-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: #000;
  overflow: hidden;
}

/* ===== 相机 ===== */
.ar-camera {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* ===== WebGL Canvas ===== */
.ar-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

/* ===== 状态指示器 ===== */
.ar-status-bar {
  position: absolute;
  top: 120rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 10;
}

.ar-status-indicator {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-md);
  background: rgba(0, 0, 0, 0.55);
  backdrop-filter: blur(16rpx);
  -webkit-backdrop-filter: blur(16rpx);
  border-radius: var(--radius-round);
  transition: all 0.3s ease;
}

.ar-status-indicator.tracking {
  background: rgba(46, 139, 87, 0.75);
}

.ar-status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--color-warning);
  margin-right: var(--spacing-xs);
  animation: pulse 1.5s ease-in-out infinite;
}

.ar-status-indicator.tracking .ar-status-dot {
  background: #fff;
  animation: none;
}

@keyframes pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.5; transform: scale(0.8); }
}

.ar-status-text {
  font-size: var(--font-size-xs);
  color: #fff;
  white-space: nowrap;
}

/* ===== 顶部操作栏 ===== */
.ar-top-bar {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  padding-top: calc(var(--spacing-md) + constant(status-bar-height));
  padding-top: calc(var(--spacing-md) + env(status-bar-height));
  z-index: 10;
}

.ar-close-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: var(--radius-round);
}

.ar-close-icon {
  font-size: var(--font-size-md);
  color: #fff;
}

.ar-switch-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(12rpx);
  -webkit-backdrop-filter: blur(12rpx);
  border-radius: var(--radius-round);
}

.ar-switch-icon {
  width: 36rpx;
  height: 36rpx;
  filter: brightness(0) invert(1);
}

/* ===== 权限引导/降级 ===== */
.ar-permission-guide {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg);
  z-index: 20;
}

.ar-guide-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
  text-align: center;
}

.ar-guide-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: var(--spacing-lg);
  opacity: 0.6;
}

.ar-guide-title {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: var(--spacing-sm);
}

.ar-guide-desc {
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: var(--spacing-lg);
  max-width: 500rpx;
}

.ar-guide-actions {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  width: 100%;
  max-width: 400rpx;
}

.ar-guide-actions .btn {
  width: 100%;
}
