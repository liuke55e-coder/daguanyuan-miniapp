/* pages/index/index.wxss - 首页地图样式 */

.page-container {
  position: relative;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ===== 地图区域 ===== */
.map-area {
  flex: 1;
  position: relative;
  overflow: hidden;
}

/* AR入口按钮 */
.ar-entry {
  position: absolute;
  right: var(--spacing-md);
  bottom: 200rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  z-index: 10;
}

.ar-entry:active {
  transform: scale(0.92);
  transition: transform 0.15s ease;
}

.ar-icon {
  width: 44rpx;
  height: 44rpx;
  margin-bottom: 4rpx;
}

.ar-text {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  font-weight: 500;
}

/* 位置授权提示 */
.location-tip {
  position: absolute;
  top: var(--spacing-md);
  left: var(--spacing-md);
  right: var(--spacing-md);
  padding: var(--spacing-sm) var(--spacing-md);
  background: rgba(255, 255, 255, 0.95);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: var(--font-size-sm);
  color: var(--color-text-secondary);
  z-index: 10;
}

.location-tip-link {
  color: var(--color-primary);
  font-weight: 600;
  padding: 4rpx 16rpx;
}

/* ===== 路线选择器 ===== */
.route-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border-top: 1rpx solid var(--color-divider);
  padding-bottom: calc(var(--spacing-sm) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--spacing-sm) + env(safe-area-inset-bottom));
}

.route-scroll {
  flex: 1;
  white-space: nowrap;
}

.route-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 180rpx;
  height: 100rpx;
  margin-right: var(--spacing-sm);
  padding: var(--spacing-xs) var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-md);
  border: 2rpx solid transparent;
  transition: all 0.25s ease;
}

.route-item.active {
  background: rgba(196, 30, 58, 0.06);
  border-color: var(--route-color, var(--color-primary));
}

.route-name {
  font-size: var(--font-size-sm);
  font-weight: 600;
  color: var(--color-text);
}

.route-item.active .route-name {
  color: var(--route-color, var(--color-primary));
}

.route-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.route-clear {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: var(--spacing-sm);
  background: var(--color-bg);
  border-radius: var(--radius-round);
  font-size: var(--font-size-md);
  color: var(--color-text-secondary);
}
