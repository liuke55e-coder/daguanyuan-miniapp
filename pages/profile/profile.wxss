/* pages/profile/profile.wxss - 我的页面样式 */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--color-bg);
}

.profile-scroll {
  flex: 1;
}

/* ===== 顶部用户信息 ===== */
.profile-header {
  position: relative;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 240rpx;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
}

.header-content {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md) var(--spacing-lg);
  z-index: 1;
}

.avatar-wrap {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--radius-round);
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  overflow: hidden;
  margin-bottom: var(--spacing-sm);
  background: var(--color-bg-card);
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.user-name {
  font-size: var(--font-size-lg);
  font-weight: 700;
  color: #fff;
  margin-bottom: 4rpx;
}

.user-desc {
  font-size: var(--font-size-xs);
  color: rgba(255, 255, 255, 0.7);
}

/* ===== 数据统计 ===== */
.stats-bar {
  display: flex;
  align-items: center;
  margin: var(--spacing-md);
  padding: var(--spacing-md) var(--spacing-sm);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  margin-top: -20rpx;
  position: relative;
  z-index: 2;
}

.stat-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-number {
  font-size: var(--font-size-xl);
  font-weight: 700;
  color: var(--color-primary);
  font-family: var(--font-family-title);
  line-height: 1.2;
}

.stat-label {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--color-divider);
}

/* ===== 通用区块 ===== */
.section {
  padding: 0 var(--spacing-md);
  margin-bottom: var(--spacing-lg);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-sm);
}

.section-title {
  font-size: var(--font-size-md);
  font-weight: 700;
  color: var(--color-text);
}

.section-more {
  font-size: var(--font-size-sm);
  color: var(--color-primary);
}

/* ===== 收藏预览 ===== */
.favorites-preview {
  display: flex;
  gap: var(--spacing-sm);
  overflow-x: auto;
  padding-bottom: var(--spacing-xs);
}

.fav-item {
  flex-shrink: 0;
  width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.fav-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--radius-md);
  background: var(--color-divider);
  margin-bottom: var(--spacing-xs);
}

.fav-name {
  font-size: var(--font-size-xs);
  color: var(--color-text-secondary);
  text-align: center;
}

/* ===== 游览列表 ===== */
.visit-list {
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.visit-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-sm) var(--spacing-md);
  border-bottom: 1rpx solid var(--color-divider);
}

.visit-item:last-child {
  border-bottom: none;
}

.visit-name {
  flex: 1;
  font-size: var(--font-size-sm);
  font-weight: 500;
  color: var(--color-text);
}

.visit-count {
  font-size: var(--font-size-xs);
  color: var(--color-primary);
  margin-right: var(--spacing-sm);
  font-weight: 600;
}

.visit-time {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}

/* ===== 空状态 ===== */
.empty-hint {
  padding: var(--spacing-lg) 0;
  text-align: center;
  font-size: var(--font-size-sm);
  color: var(--color-text-light);
}

/* ===== 关于 ===== */
.about-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-md);
  background: var(--color-bg-card);
  border-radius: var(--radius-md);
}

.about-item:active {
  background: var(--color-divider);
}

.about-text {
  font-size: var(--font-size-sm);
  color: var(--color-text);
}

.about-arrow {
  font-size: var(--font-size-lg);
  color: var(--color-text-light);
}

/* ===== 底部 ===== */
.profile-footer {
  padding: var(--spacing-lg) var(--spacing-md);
  text-align: center;
  padding-bottom: calc(var(--spacing-lg) + constant(safe-area-inset-bottom));
  padding-bottom: calc(var(--spacing-lg) + env(safe-area-inset-bottom));
}

.footer-text {
  font-size: var(--font-size-xs);
  color: var(--color-text-light);
}
